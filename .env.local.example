# Copy this file to .env.local and fill in your values

# Your production URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://cameras.getsecure.co.nz

# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Quote form endpoint (POST target for QuoteForm submissions)
# Use a form backend like Formspree, EmailJS, or your own API route
NEXT_PUBLIC_FORM_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
